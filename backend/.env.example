# Server
PORT=10000
NODE_ENV=development
# Comma-separated allowed browser origins
CORS_ORIGIN=http://localhost:5173

# Local Postgres (docker compose up -d)
DATABASE_URL="postgresql://ecoverify:ecoverify@localhost:5432/ecoverify?schema=public"

# On Render this is injected automatically from ecoverify-db.
# For local debugging against Render, paste the External Database URL instead.

# AI provider: auto | ollama | openai | mock
AI_PROVIDER=auto

# Ollama (local only — not available on free Render)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CHAT_MODEL=llama3.2
OLLAMA_VISION_MODEL=llava

# OpenAI fallback (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
