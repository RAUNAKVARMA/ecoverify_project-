# Server
PORT=10000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Postgres (optional for now — classify works without DB)
DATABASE_URL=postgresql://ecoverify:ecoverify@localhost:5432/ecoverify?schema=public

# AI provider: auto | ollama | openai | mock
AI_PROVIDER=auto

# Ollama (run locally; pull vision model: ollama pull llava)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CHAT_MODEL=llama3.2
OLLAMA_VISION_MODEL=llava

# OpenAI fallback (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
